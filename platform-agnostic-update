#!/usr/bin/env bash
#
# install-tools.sh
# Cross-distro dev tooling installer — package managers only, idempotent.
#
# Supported platforms (auto-detected):
#   - arch        Arch Linux                (pacman + AUR helper)
#   - wsl-ubuntu  Ubuntu under WSL 2        (apt + npm)
#   - asahi       Fedora Asahi Remix on M1  (dnf + npm)
#
# Tools: bazelisk, neovim, tmux, fzf, ripgrep
#        + NVIDIA CUDA dev tools  (arch and wsl-ubuntu ONLY — never on Asahi)
#
# Idempotent: anything already present is detected and SKIPPED with a message,
# so re-running won't reinstall or silently upgrade. In particular, CUDA is left
# untouched if a toolkit already exists (the apt `cuda-toolkit` meta-package
# otherwise rolls forward to the newest release on every run).
#
# Override with FORCE=1 to (re)install/upgrade everything anyway:
#     FORCE=1 ./install-tools.sh
#
set -euo pipefail

FORCE="${FORCE:-0}"

# --------------------------------------------------------------------------
# Helpers
# --------------------------------------------------------------------------
log()  { printf '\033[1;32m==>\033[0m %s\n' "$*"; }
skip() { printf '\033[1;34m-- \033[0m%s\n' "$*"; }
warn() { printf '\033[1;33m!! \033[0m%s\n' "$*" >&2; }
die()  { printf '\033[1;31mxx \033[0m%s\n' "$*" >&2; exit 1; }

PLATFORM=""

detect_platform() {
  local id="" id_like=""
  if [[ -r /etc/os-release ]]; then
    # shellcheck disable=SC1091
    . /etc/os-release; id="${ID:-}"; id_like="${ID_LIKE:-}"
  fi
  local is_wsl="no"
  if [[ -n "${WSL_DISTRO_NAME:-}" ]] || grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
    is_wsl="yes"
  fi
  if [[ "$is_wsl" == "yes" ]] && [[ "$id" =~ (ubuntu|debian) || "$id_like" =~ debian ]]; then
    PLATFORM="wsl-ubuntu"
  elif [[ "$id" == "arch" || "$id_like" =~ arch ]]; then
    PLATFORM="arch"
  elif [[ "$id" == "fedora" || "$id_like" =~ fedora ]]; then
    PLATFORM="asahi"
  else
    die "Unsupported / undetected platform (ID='$id')."
  fi
  log "Platform: ${PLATFORM} ($(uname -m))   FORCE=${FORCE}"
}

pm_install() {
  case "$PLATFORM" in
    arch)       sudo pacman -S --needed --noconfirm "$@" ;;
    wsl-ubuntu) sudo apt-get install -y "$@" ;;
    asahi)      sudo dnf install -y "$@" ;;
  esac
}

pm_refresh() {
  case "$PLATFORM" in
    wsl-ubuntu) sudo apt-get update ;;
    *) : ;;
  esac
}

aur_helper() {
  local h; for h in yay paru; do command -v "$h" >/dev/null 2>&1 && { echo "$h"; return 0; }; done
  return 1
}

# Install a package only if its command is missing (or FORCE=1).
#   ensure_pkg <check-command> <package(s)...>
ensure_pkg() {
  local cmd="$1"; shift
  if [[ "$FORCE" != "1" ]] && command -v "$cmd" >/dev/null 2>&1; then
    skip "${cmd} already installed ($(command -v "$cmd")) — skipping"
    return 0
  fi
  log "Installing ${cmd} (packages: $*)"
  pm_install "$@"
}

add_to_shell_rc() {
  local marker="$1" block="$2" rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ -e "$rc" ]] || continue
    if ! grep -qF "$marker" "$rc"; then
      { printf '\n# %s\n' "$marker"; printf '%s\n' "$block"; } >> "$rc"
      log "Updated $rc"
    fi
  done
}

# --------------------------------------------------------------------------
# CUDA detection
# --------------------------------------------------------------------------
cuda_nvcc_path() {
  if command -v nvcc >/dev/null 2>&1;      then command -v nvcc; return 0; fi
  if [[ -x /usr/local/cuda/bin/nvcc ]];    then echo /usr/local/cuda/bin/nvcc; return 0; fi
  if [[ -x /opt/cuda/bin/nvcc ]];          then echo /opt/cuda/bin/nvcc; return 0; fi
  return 1
}

report_cuda() {
  local nvcc; nvcc="$(cuda_nvcc_path)" || return 0
  log "CUDA present: $("$nvcc" --version 2>/dev/null | grep -i release || echo "$nvcc")"
  [[ -L /usr/local/cuda ]] && log "  /usr/local/cuda -> $(readlink -f /usr/local/cuda)"
  [[ -d /opt/cuda ]]       && log "  /opt/cuda (Arch toolkit dir present)"
}

# --------------------------------------------------------------------------
# Installers
# --------------------------------------------------------------------------
install_prereqs() {
  log "Ensuring prerequisites"
  case "$PLATFORM" in
    wsl-ubuntu) pm_install curl ca-certificates git wget gnupg ;;
    *)          pm_install curl ca-certificates git ;;
  esac
}

install_common_tools() {
  ensure_pkg nvim neovim
  ensure_pkg tmux tmux
  ensure_pkg fzf  fzf
  ensure_pkg rg   ripgrep
}

install_bazelisk() {
  if [[ "$FORCE" != "1" ]] && command -v bazelisk >/dev/null 2>&1; then
    skip "bazelisk already installed ($(command -v bazelisk)) — skipping"
    return 0
  fi
  case "$PLATFORM" in
    arch)
      local helper
      helper="$(aur_helper)" || die "No AUR helper (yay/paru) for bazelisk-bin. Install yay or ask for a makepkg fallback."
      log "Installing bazelisk via ${helper} (AUR: bazelisk-bin)"
      "$helper" -S --needed --noconfirm bazelisk-bin
      ;;
    wsl-ubuntu|asahi)
      log "Installing bazelisk via npm (@bazel/bazelisk) — pulls in Node.js"
      ensure_pkg npm npm
      sudo npm install -g @bazel/bazelisk
      ;;
  esac
}

install_cuda() {
  if [[ "$PLATFORM" == "asahi" ]]; then
    skip "CUDA: not applicable on Asahi (M1 GPU is not NVIDIA) — skipping"
    return 0
  fi

  if [[ "$FORCE" != "1" ]] && cuda_nvcc_path >/dev/null; then
    skip "CUDA already installed — skipping (set FORCE=1 to reinstall/upgrade)"
    report_cuda
    return 0
  fi

  case "$PLATFORM" in
    arch)
      log "Installing CUDA dev tools via pacman (cuda -> /opt/cuda)"
      pm_install cuda
      add_to_shell_rc "cuda (arch) PATH" \
'export PATH="/opt/cuda/bin:$PATH"
export LD_LIBRARY_PATH="/opt/cuda/lib64:${LD_LIBRARY_PATH:-}"'
      ;;
    wsl-ubuntu)
      log "Installing CUDA dev tools for WSL 2 (driverless wsl-ubuntu toolkit)"
      # Never install an NVIDIA driver in WSL — the Windows host driver is
      # mapped in as libcuda.so. Install ONLY the toolkit.
      local keyring; keyring="$(mktemp --suffix=.deb)"
      curl -fL --retry 3 -o "$keyring" \
        "https://developer.download.nvidia.com/compute/cuda/repos/wsl-ubuntu/x86_64/cuda-keyring_1.1-1_all.deb"
      sudo dpkg -i "$keyring"; rm -f "$keyring"
      sudo apt-get update
      # `cuda-toolkit` = latest toolkit, no driver. To PIN a version instead and
      # avoid future roll-forward, use e.g. cuda-toolkit-12-8.
      sudo apt-get install -y cuda-toolkit
      add_to_shell_rc "cuda (wsl) PATH" \
'export PATH="/usr/local/cuda/bin:$PATH"
export LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}"'
      ;;
  esac
}

# --------------------------------------------------------------------------
# Main
# --------------------------------------------------------------------------
main() {
  [[ "$(id -u)" -eq 0 ]] && warn "Running as root; shell rc edits target root's home."
  detect_platform
  pm_refresh
  install_prereqs
  install_common_tools
  install_bazelisk
  install_cuda
  log "Done."
  [[ "$PLATFORM" != "asahi" ]] && echo "If CUDA changed, open a new shell then: nvcc --version"
  echo "Verify: nvim --version | head -n1 ; tmux -V ; fzf --version ; rg --version | head -n1 ; bazelisk version | head -n1"
}

main "$@"
