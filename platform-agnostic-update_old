#!/usr/bin/env bash
#
# install-tools.sh
# Cross-distro dev tooling installer — package managers only, no raw binaries.
#
# Supported platforms (auto-detected):
#   - arch        Arch Linux                (pacman + AUR helper)
#   - wsl-ubuntu  Ubuntu under WSL 2        (apt + npm)
#   - asahi       Fedora Asahi Remix on M1  (dnf + npm)
#
# Tools:
#   bazelisk, neovim, tmux, fzf, ripgrep
#   + NVIDIA CUDA dev tools  (arch and wsl-ubuntu ONLY — never on Asahi)
#
# Every tool is installed through a package manager:
#   neovim/tmux/fzf/ripgrep  -> pacman / apt / dnf
#   bazelisk                 -> AUR (Arch) / npm (Ubuntu, Asahi)
#   cuda                     -> pacman `cuda` / apt `cuda-toolkit`
#
# Note: on Ubuntu/Asahi the bazelisk route pulls in Node.js via npm. That's the
# tradeoff for an all-package-manager setup; a standalone binary would avoid it.
#
# Re-running is safe: installs use --needed/idempotent flags and the shell-rc
# edits are guarded against duplication.
#
set -euo pipefail

# --------------------------------------------------------------------------
# Helpers
# --------------------------------------------------------------------------
log()  { printf '\033[1;32m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!! \033[0m%s\n' "$*" >&2; }
die()  { printf '\033[1;31mxx \033[0m%s\n' "$*" >&2; exit 1; }

PLATFORM=""

detect_platform() {
  local id="" id_like=""
  if [[ -r /etc/os-release ]]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    id="${ID:-}"; id_like="${ID_LIKE:-}"
  fi

  local is_wsl="no"
  if [[ -n "${WSL_DISTRO_NAME:-}" ]] || grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
    is_wsl="yes"
  fi

  if [[ "$is_wsl" == "yes" ]] && [[ "$id" =~ (ubuntu|debian) || "$id_like" =~ debian ]]; then
    PLATFORM="wsl-ubuntu"
  elif [[ "$id" == "arch" || "$id_like" =~ arch ]]; then
    PLATFORM="arch"
  elif [[ "$id" == "fedora" || "$id_like" =~ fedora ]]; then
    PLATFORM="asahi"   # Fedora Asahi Remix (aarch64 Apple Silicon)
  else
    die "Unsupported / undetected platform (ID='$id'). Edit this script to add it."
  fi
  log "Detected platform: ${PLATFORM} ($(uname -m))"
}

# Native package install for the current platform.
pm_install() {
  case "$PLATFORM" in
    arch)       sudo pacman -S --needed --noconfirm "$@" ;;
    wsl-ubuntu) sudo apt-get install -y "$@" ;;
    asahi)      sudo dnf install -y "$@" ;;
  esac
}

pm_refresh() {
  case "$PLATFORM" in
    arch)       : ;;  # rely on --needed; run `sudo pacman -Syu` yourself to fully update
    wsl-ubuntu) sudo apt-get update ;;
    asahi)      : ;;  # dnf refreshes metadata automatically
  esac
}

# First available AUR helper, or empty.
aur_helper() {
  local h
  for h in yay paru; do command -v "$h" >/dev/null 2>&1 && { echo "$h"; return 0; }; done
  return 1
}

# Append a guarded block to the user's shell rc files (bash + zsh) exactly once.
add_to_shell_rc() {
  local marker="$1" block="$2" rc
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ -e "$rc" ]] || continue
    if ! grep -qF "$marker" "$rc"; then
      { printf '\n# %s\n' "$marker"; printf '%s\n' "$block"; } >> "$rc"
      log "Updated $rc"
    fi
  done
}

# --------------------------------------------------------------------------
# Tool installers
# --------------------------------------------------------------------------
install_prereqs() {
  log "Installing prerequisites"
  case "$PLATFORM" in
    arch)       pm_install curl ca-certificates git ;;
    wsl-ubuntu) pm_install curl ca-certificates git wget gnupg ;;
    asahi)      pm_install curl ca-certificates git ;;
  esac
}

install_common_tools() {
  log "Installing neovim, tmux, fzf, ripgrep (native packages)"
  pm_install neovim tmux fzf ripgrep
  # Ubuntu's apt neovim can lag upstream; ask me to swap in the official
  # release tarball if you need a newer version for plugins.
}

install_bazelisk() {
  case "$PLATFORM" in
    arch)
      local helper
      if ! helper="$(aur_helper)"; then
        die "No AUR helper (yay/paru) found — needed for bazelisk-bin. Install yay, or ask me for a makepkg fallback."
      fi
      log "Installing bazelisk via ${helper} (AUR: bazelisk-bin)"
      "$helper" -S --needed --noconfirm bazelisk-bin
      ;;
    wsl-ubuntu|asahi)
      log "Installing bazelisk via npm (@bazel/bazelisk) — pulls in Node.js"
      pm_install npm
      sudo npm install -g @bazel/bazelisk
      ;;
  esac
  command -v bazelisk >/dev/null 2>&1 \
    && log "bazelisk: $(bazelisk version 2>/dev/null | head -n1 || echo installed)"
}

install_cuda() {
  case "$PLATFORM" in
    asahi)
      warn "Skipping CUDA on Asahi — the M1 GPU is not NVIDIA, CUDA cannot run here."
      ;;
    arch)
      log "Installing CUDA dev tools via pacman (package: cuda -> /opt/cuda)"
      pm_install cuda
      add_to_shell_rc "cuda (arch) PATH" \
'export PATH="/opt/cuda/bin:$PATH"
export LD_LIBRARY_PATH="/opt/cuda/lib64:${LD_LIBRARY_PATH:-}"'
      ;;
    wsl-ubuntu)
      log "Installing CUDA dev tools for WSL 2 (driverless wsl-ubuntu toolkit)"
      # IMPORTANT: never install an NVIDIA *driver* inside WSL. The Windows host
      # driver is mapped in as libcuda.so. Install ONLY the toolkit.
      local keyring; keyring="$(mktemp --suffix=.deb)"
      curl -fL --retry 3 -o "$keyring" \
        "https://developer.download.nvidia.com/compute/cuda/repos/wsl-ubuntu/x86_64/cuda-keyring_1.1-1_all.deb"
      sudo dpkg -i "$keyring"; rm -f "$keyring"
      sudo apt-get update
      # cuda-toolkit = latest toolkit WITHOUT the bundled driver.
      # (Do NOT use `apt install nvidia-cuda-toolkit` — stale Ubuntu package.)
      sudo apt-get install -y cuda-toolkit
      add_to_shell_rc "cuda (wsl) PATH" \
'export PATH="/usr/local/cuda/bin:$PATH"
export LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}"'
      ;;
  esac
}

# --------------------------------------------------------------------------
# Main
# --------------------------------------------------------------------------
main() {
  [[ "$(id -u)" -eq 0 ]] && warn "Running as root; per-user shell rc edits will target root's home."
  detect_platform
  pm_refresh
  install_prereqs
  install_common_tools
  install_bazelisk
  install_cuda
  log "All done."
  if [[ "$PLATFORM" != "asahi" ]]; then
    echo; echo "Open a new shell (or source your rc), then verify CUDA: nvcc --version"
  fi
  echo "Verify the rest: nvim --version | head -n1 ; tmux -V ; fzf --version ; rg --version | head -n1 ; bazelisk version | head -n1"
}

main "$@"
